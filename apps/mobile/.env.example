# Copy to .env and fill in.
#
# NOTE: .env.local takes precedence over .env (Expo loads .env.local first).
# If .env.local sets EXPO_PUBLIC_CONVEX_URL, that wins. Scripts like
# sync-celebrity-heads-db.js also follow this order.
#
# Prod: https://next-ladybug-891.convex.cloud
# Dev: run "npx convex dev", then use the URL it prints
EXPO_PUBLIC_CONVEX_URL=https://your-project.convex.cloud

# Preview server IP (your machine's LAN IP so the phone can reach Vite)
EXPO_PUBLIC_PREVIEW_URL=http://192.168.x.x:5173

# AWS / S3
S3_BUCKET=eid-meme-maker-assets
AWS_REGION=us-east-1
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=

# PhotoRoom background removal API (set in Convex env for uploads.removeBackground)
# Get keys from https://app.photoroom.com/api
PHOTOROOM_API_KEY=
PHOTOROOM_SANDBOX_API_KEY=
