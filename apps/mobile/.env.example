# Copy to .env and fill in. Use ONE Convex URL (prod or dev).
# Prod: https://next-ladybug-891.convex.cloud
# Dev: run "npx convex dev", then use the URL it prints (e.g. https://moonlit-meadowlark-37.convex.cloud)
EXPO_PUBLIC_CONVEX_URL=https://your-project.convex.cloud

# PhotoRoom background removal API (set in Convex env for uploads.removeBackground)
# Get keys from https://app.photoroom.com/api
PHOTOROOM_API_KEY=your_photoroom_api_key_here
PHOTOROOM_SANDBOX_API_KEY=your_photoroom_sandbox_api_key_here
