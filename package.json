{
  "name": "eid-meme-maker",
  "private": true,
  "workspaces": [
    "apps/*",
    "packages/*"
  ],
  "dependencies": {
    "@aws-sdk/client-s3": "^3.700.0",
    "@aws-sdk/s3-request-presigner": "^3.700.0",
    "lightningcss-darwin-arm64": "^1.31.1"
  },
  "scripts": {
    "dev": "turbo dev",
    "dev:all": "concurrently -n preview,mobile -c blue,green \"bun run --cwd apps/preview dev\" \"bun run mobile\"",
    "build": "turbo build",
    "test": "turbo test",
    "lint": "turbo lint",
    "mobile": "cd apps/mobile && bun run start",
    "mobile:ios": "cd apps/mobile && bun run ios",
    "mobile:android": "cd apps/mobile && bun run android"
  },
  "devDependencies": {
    "concurrently": "^9.1.2",
    "jest": "^29.7.0",
    "turbo": "^2"
  },
  "packageManager": "bun@1.1.0",
  "optionalDependencies": {
    "@rollup/rollup-darwin-arm64": "^4.59.0"
  },
  "overrides": {
    "p-limit": "3.1.0"
  }
}
